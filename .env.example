# ============================================================
# App URLs
# ============================================================
NODE_ENV="development"
WEB_PORT="3000"
API_PORT="3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
API_PUBLIC_BASE_URL="http://localhost:3001"
API_BASE_URL="http://api:3001"
PARTNER_UPLOAD_URL="http://localhost:3000/csp-partners"
NEXT_PUBLIC_ASSET_BASE_URL=""
NEXT_PUBLIC_ENABLE_DEMO="false"

# Optional origin overrides for generated public links
APP_ORIGIN=""
NEXT_PUBLIC_APP_ORIGIN=""
SITE_URL=""
NEXT_PUBLIC_SITE_URL=""
PPT_PUBLIC_ORIGIN=""

# ============================================================
# Authentication
# ============================================================
AUTH_SECRET=""                           # Required
NEXTAUTH_SECRET=""                       # Optional compatibility alias
AUTH_TRUST_HOST="true"

# Internal Microsoft Entra app
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""

# Reseller Microsoft Entra app
AZURE_AD_RESELLER_CLIENT_ID=""
AZURE_AD_RESELLER_CLIENT_SECRET=""

# Reseller Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional tenant controls
ALLOWED_TENANT_IDS=""
DEFAULT_TENANT_ID="default-tenant"
MICROSOFT_TENANT_ID=""
HSV_DIGITAL_TENANT_ID=""
NEXT_PUBLIC_HSV_DIGITAL_TENANT_ID=""
INTERNAL_ADMIN_TENANT_ID=""
INTERNAL_TENANT_LABELS=""

# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/projectb"
POSTGRES_USER="postgres"                 # Docker local only
POSTGRES_PASSWORD="postgres"             # Docker local only
POSTGRES_DB="projectb"                   # Docker local only

# Optional compatibility vars when DATABASE_URL is not used
PGHOST=""
PGPORT="5432"
PGUSER=""
PGPASSWORD=""
PGDATABASE=""
DB_SSL="false"
PGSSLMODE=""

# ============================================================
# Redis
# ============================================================
REDIS_URL="redis://:redis@redis:6379/0"
REDIS_HOST="redis"                       # Compatibility fallback
REDIS_PORT="6379"                        # Compatibility fallback
REDIS_PASSWORD="redis"                   # Compatibility fallback
REDIS_DB="0"                             # Compatibility fallback

# ============================================================
# Storage and CDN
# ============================================================
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""
AZURE_STORAGE_CONTAINER_NAME="proposal-assets"
AZURE_CDN_BASE_URL=""
BLOB_SAS_EXPIRY_SECONDS="604800"

# Optional runtime asset-path overrides for apps/api
GTM_ASSETS_DIR="./static/gtm-assets"
EMAIL_TEMPLATES_DIR="./assets/email_templates"
PROPOSAL_FLYERS_DIR="./assets/flyers"

# ============================================================
# Analytics
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_PROJECT_TOKEN=""
POSTHOG_CAPTURE_HOST="https://us.i.posthog.com"
POSTHOG_ENDPOINT_API_KEY=""
POSTHOG_PERSONAL_API_KEY=""
POSTHOG_WEB_PROJECT_ID=""
POSTHOG_QUERY_HOST="https://us.posthog.com"

# ============================================================
# PDF, download-link, and token secrets
# ============================================================
DL_TOKEN_ENCRYPTION_KEY=""
PDF_DL_TOKEN_SECRET=""
PDF_DL_TOKEN_TTL_SECONDS="3600"
PDF_PASSWORD_ENCRYPTION_KEY=""
PPT_TOKEN_SECRET=""
PPT_TOKEN_TTL_SECONDS="900"
RESELLER_API_TOKEN_SECRET=""
RESELLER_API_TOKEN_TTL_SECONDS="604800"
PROPOSAL_OPTIONS_EMAIL_TOKEN_TTL_SECONDS="600"

# ============================================================
# PDF rendering and worker tuning
# ============================================================
PDF_RENDER_TIMEOUT_MS="15000"
PDF_MAX_CONCURRENCY="4"
PDF_CACHE_TTL_SECONDS="120"
PDF_RENDER_CACHE_VERSION="v2"
PDF_ASYNC_MIN_PART_SIZE="1000"
PDF_ASYNC_PART_SIZE="10000"
PDF_ASYNC_SPLIT_MAX_DEPTH="4"
QPDF_BINARY="qpdf"

# ============================================================
# Feature and deployment tuning
# ============================================================
PROPOSAL_GENERATION_SELECTION_SNAPSHOT_LAUNCH_AT="2026-03-07T00:00:00.000Z"
RESELLER_EXCLUDED_ORG_DOMAINS=""
APP_ENV_FILE=""
