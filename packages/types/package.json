{
	"name": "@repo/types",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"typesVersions": {
		"*": {
			".": [
				"./dist/index.d.ts"
			]
		}
	},
	"files": [
		"./dist/**"
	],
	"scripts": {
		"build": "tsc -p .",
		"dev": "tsc -p . --watch"
	},
	"devDependencies": {
		"@repo/typescript-config": "*",
		"typescript": "^5"
	}
}
