# Derived subset for running apps/web in isolation.
# Canonical source of truth: ../../.env.example
# For partner deployments and docker compose, use the repo root .env file.

# ============================================================
# App URLs
# ============================================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_ASSET_BASE_URL=""
NEXT_PUBLIC_ENABLE_DEMO="false"

# Optional origin overrides for generated public links
APP_ORIGIN=""
NEXT_PUBLIC_APP_ORIGIN=""
SITE_URL=""
NEXT_PUBLIC_SITE_URL=""
PPT_PUBLIC_ORIGIN=""

# ============================================================
# Authentication
# ============================================================
AUTH_SECRET=""
NEXTAUTH_SECRET=""
AUTH_TRUST_HOST="true"
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_RESELLER_CLIENT_ID=""
AZURE_AD_RESELLER_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================================
# Analytics
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_HSV_DIGITAL_TENANT_ID=""

# ============================================================
# PPT and token settings
# ============================================================
PPT_TOKEN_SECRET=""
PPT_TOKEN_TTL_SECONDS="900"
