<script type="text/javascript">
    window.onload = function() {
        if (window.navigator.appName == "Microsoft Internet Explorer" || window.navigator.userAgent.indexOf("Trident") > 0) {
            var searchElement = document.getElementById("search");
            if (searchElement != null) searchElement.setAttribute("href", "");
        }
    };
    function setHeight() {
        var windowHeight = window.innerHeight - 140;
        var navbar = document.getElementById("navbar");
        if (navbar) {
            navbar.style.maxHeight = windowHeight + "px";
        }
    }
    window.addEventListener('resize', function(event) {
        setHeight();
    });

    window.addEventListener("load", fetchHeaderFooter, false);

    function fetchHeaderFooter() {
        let url = "https://uhf.microsoft.com/us/shell/xml/MSPowerAppsPortal?headerid=MSPowerAppsPortalHeader&footerid=MSPowerAppsPortalFooter";

        $.ajax({
            method: "GET",
            url: url,
            dataType: "xml",
        }).done((msg) => {
            var responsexml = msg;
            var cssIncludes = $(responsexml).find("cssIncludes")[0].childNodes[1].data.trim();
            let styles = $.parseHTML(cssIncludes);
            $("head").append(styles);

            var headerHtml = $(responsexml).find("headerHtml")[0].childNodes[1].data.trim();
            document.getElementById("page-header").innerHTML = headerHtml;

            var footerHtml = $(responsexml).find("footerHtml")[0].childNodes[1].data.trim();
            document.getElementById("customFooter").innerHTML = footerHtml;

            const links = document.querySelectorAll('#customFooter li a');
            links.forEach(link => {
                link.style.setProperty('margin-left','0','important')
            });

            var javascriptIncludes = $(responsexml).find("javascriptIncludes")[0].childNodes[1].data.trim();
            let scripts = $.parseHTML(javascriptIncludes, true);
            $("head").append(scripts);
        });
    }
</script>
	

