<script>

  const returnUrl = encodeURIComponent(
    window.location.pathname + window.location.search + window.location.hash
  );

  // --- Sign In link setup ---
  const signInLink = document.getElementById("signin-link");
  if (signInLink) {
    signInLink.href = `/Account/Login?returnUrl=${returnUrl}`;
  }

  // --- Utility function ---
  function normalizePath(path) {
    path = path.toLowerCase();
    return path.endsWith('/') ? path : path + '/';
  }

  const currentPath = normalizePath(window.location.pathname);

  // --- Secure paths for sign-out handling ---
  const securePaths = [
    "/microsoft-security-partners/ea-envisioning-workshops/",
    "/microsoft-security-partners/immersion-briefings/",
    "/microsoft-security-partners/envisioning-workshops/",
    "/microsoft-security-partners/accelerate-your-csp-security-business/"
  ];

  // --- Sign Out link setup ---
  const signOutLink = document.getElementById("signout-link");
  if (signOutLink) {
    const isSecurePage = securePaths.includes(currentPath);
    signOutLink.href = isSecurePage
      ? `/Account/Login/LogOff?returnUrl=/`
      : `/Account/Login/LogOff?returnUrl=${returnUrl}`;
  }

  // --- Optional: Click handling (for dynamic or single-page apps) ---
  document.addEventListener("click", function (e) {
    const target = e.target;

    // Sign In link
    if (target.id === "signin-link") {
      e.preventDefault();
      window.location.href = `/Account/Login?returnUrl=${returnUrl}`;
    }

    // Sign Out link
    if (target.id === "signout-link") {
      e.preventDefault();
      const isSecurePage = securePaths.includes(currentPath);
      const logoutUrl = isSecurePage
        ? `/Account/Login/LogOff?returnUrl=/`
        : `/Account/Login/LogOff?returnUrl=${returnUrl}`;
      window.location.href = logoutUrl;
    }
  });


  document.addEventListener("DOMContentLoaded", () => {
    const hamburger = document.querySelector(".hamburger");
    const navItems = document.getElementById("nav-items");
    const searchToggle = document.querySelector(".search-toggle");
    const searchContainer = document.getElementById("search-container");
    const searchClose = document.querySelector(".search-close");
    const searchInput = document.getElementById("navbar-search");
    const dropdownToggles = document.querySelectorAll(".dropdown-toggle");
    const navbar = document.querySelector(".custom-navbar");
    const allNavItems = Array.from(navItems.children);

    function closeAllDropdowns() {
      document.querySelectorAll(".dropdown-menu-manual").forEach(menu => {
        menu.classList.remove("show");
        menu.setAttribute("aria-hidden", "true");
      });
      document.querySelectorAll(".dropdown-toggle").forEach(btn =>
        btn.setAttribute("aria-expanded", "false")
      );
    }

    function adjustNavItemsForSearch() {
      if (window.innerWidth <= 900) {
        resetNavItems();
        return;
      }

      const navbarWidth = navbar.offsetWidth;
      const profileDropdownWidth = document.querySelector('.profile-dropdown.desktop-only').offsetWidth;
      const SEARCH_ACTIVE_WIDTH = 540;
      const rightSideStaticWidth = profileDropdownWidth + 12;
      const availableWidth = navbarWidth - SEARCH_ACTIVE_WIDTH - rightSideStaticWidth - 136;

      let usedWidth = 0;
      resetNavItems();

      const visibleDesktopItems = allNavItems.filter(li => !li.classList.contains('mobile-only'));

      for (let li of visibleDesktopItems) {
        li.style.display = "inline-flex";
        usedWidth += li.offsetWidth;
        if (usedWidth > availableWidth) {
          li.style.display = "none";
        }
      }
    }

    function handleSearch(event) {
      event.preventDefault(); // Prevent form submission

      const query = document.getElementById('navbar-search').value.trim();

      if (query) {
        window.location.href = `/Search-page?sitename=AI-Business-Solutions-for-Partners&query=${encodeURIComponent(query)}`;
      }

      return false;
    }

    document.getElementById('navbar-search').addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        handleSearch(event);
      }
    });

    function resetNavItems() {
      Array.from(navItems.children).forEach(li => {
        if (!li.classList.contains('mobile-only') && !li.classList.contains('desktop-only')) {
          li.style.display = "inline-flex";
        }
      });
    }

    // Event Listeners
    hamburger.addEventListener("click", () => {
      const expanded = hamburger.getAttribute("aria-expanded") === "true";
      hamburger.setAttribute("aria-expanded", String(!expanded));
      navItems.classList.toggle("show");
    });

    dropdownToggles.forEach(btn => {
      btn.addEventListener("click", e => {
        e.stopPropagation();
        const menu = document.getElementById(btn.getAttribute("aria-controls"));
        const expanded = btn.getAttribute("aria-expanded") === "true";

        closeAllDropdowns();
        if (!expanded) {
          menu.classList.add("show");
          menu.setAttribute("aria-hidden", "false");
          btn.setAttribute("aria-expanded", "true");
        }
      });
    });

    searchToggle.addEventListener("click", e => {
      e.stopPropagation();
      const isActive = searchContainer.classList.toggle("active");
      closeAllDropdowns();
      searchToggle.style.display = isActive ? "none" : "inline-flex";

      if (isActive) {
        adjustNavItemsForSearch();
        searchInput.focus();
      } else {
        resetNavItems();
      }
    });

    searchClose.addEventListener("click", () => {
      searchContainer.classList.remove("active");
      searchToggle.style.display = "inline-flex";
      resetNavItems();
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth <= 900) {
        resetNavItems();
      } else if (searchContainer.classList.contains("active")) {
        adjustNavItemsForSearch();
      } else {
        resetNavItems();
      }
    });

    document.addEventListener("click", e => {
      if (!navbar.contains(e.target)) {
        closeAllDropdowns();
        searchContainer.classList.remove("active");
        searchToggle.style.display = "inline-flex";
        resetNavItems();
      }
    });
  });
</script>

<style>
  /* ===============================
   NAVBAR BASE
=============================== */
  .custom-navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #363636;
    color: #ffffff;
    padding: 0 68px;
    height: 45px;
    position: relative;
  }

  /* ===============================
   NAVBAR LEFT SECTION
=============================== */
  .navbar-left ul {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar-left li {
    position: relative;
  }

  .divider {
    width: 2px;
    height: 30px;
    background: #fff;
    margin: 0 8px;
  }

  .navbar-left .mobile-only {
    display: none !important;
  }

  /* ===============================
   LINKS & DROPDOWN TOGGLES
=============================== */
  a.nav-link,
  .nav-link,
  .dropdown-toggle {
    color: #ffffff;
    text-decoration: none;
    padding: 0 12px 0 0;
    height: 45px;
    display: flex;
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    margin-left: 0px !important;
    gap: 4px;
  }

  a.nav-link {
    text-decoration: none !important;
  }

  a.nav-link:hover {
    text-decoration: none !important;
  }

  /* ===============================
   DROPDOWN MENU
=============================== */
  .dropdown-menu-manual {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 200px;
    background: #f4f3f5;
    color: #333;
    border-radius: 4px;
    display: none !important;
    box-shadow:
      0 0 2px rgba(0, 0, 0, 0.12),
      0 2px 4px rgba(0, 0, 0, 0.14);
    list-style: none;
    padding: 0;
    z-index: 999;
  }

  .dropdown-menu-manual.show {
    display: block !important;
  }

  .dropdown-menu-manual a {
    display: block;
    padding: 8px 36px 8px 12px;
    color: #333;
    text-decoration: none;
    position: relative;
  }

  .dropdown-menu-manual a:hover {
    background: #f3f3f3;
    text-decoration: none !important;
  }

  .dropdown-menu-manual a::after {
    content: "\2794";
    font-size: 12px;
    color: #666;
    opacity: 0;
    margin-left: 5px;
    transition: opacity 0.2s ease-in-out;
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
  }

  .dropdown-menu-manual a:hover::after {
    opacity: 1;
  }

  .dropdown-menu-manual .menu-label {
    padding: 8px 12px;
    font-weight: 400;
    font-size: 14px;
    color: #333;
    background-color: #f9f9f9;
    cursor: default;
    user-select: none;
  }

  /* ===============================
   DROPDOWN TOGGLE ARROW
=============================== */
  .dropdown-toggle {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .dropdown-arrow {
    display: inline-flex;
  }

  .dropdown-toggle[aria-expanded="true"] .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-toggle::after {
    content: none !important;
  }

  /* ===============================
   PROFILE DROPDOWN
=============================== */
  .profile-dropdown .dropdown-menu-manual {
    right: 0;
    left: auto;
  }

  .profile-dropdown .dropdown-toggle {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .profile-dropdown .dropdown-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
    margin-top: 1px;
  }

  /* ===============================
   NAVBAR RIGHT SECTION
=============================== */
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* ===============================
   SEARCH BAR
=============================== */
  .search-wrapper {
    display: flex;
    align-items: center;
  }

  .search-container {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 4px;
    overflow: hidden;
    width: 0;
    transition: width 0.3s ease;
    margin-left: auto;
  }

  .search-container.active {
    width: 500px;
  }

  .search-container input {
    flex: 1;
    border: none;
    padding: 6px 10px;
    font-size: 14px;
    outline: none;
  }

  .search-toggle {
    font-size: 14px;
    gap: 2px;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .search-close {
    background: none;
    border: none;
    font-size: 18px;
    padding: 0 8px;
    cursor: pointer;
    color: #ffffff;
    display: none;
  }

  .search-container.active+.search-close {
    display: inline-flex;
  }

  /* ===============================
   HAMBURGER
=============================== */
  .hamburger {
    background: none;
    border: none;
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    display: none;
  }

  /* ===============================
   DESKTOP VIEW (>=1201px)
=============================== */
  @media (min-width: 1201px) {
    .dropdown-menu-manual.show {
      display: flex !important;
      min-width: max-content;
    }

    .dropdown-menu-manual .column {
      flex: 1;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .dropdown-menu-manual .column+.column::before {
      content: "";
      position: absolute;
      left: 0;
      top: 12px;
      bottom: 12px;
      width: 1px;
      background-color: #ccc;
    }

    .search-wrapper {
      position: relative;
    }

    .search-container {
      position: relative;
      right: 0;
      width: 0;
      transition: width 0.3s ease, right 0.3s ease;
      background: #fff;
      border-radius: 4px;
      overflow: hidden;
      z-index: 99;
    }

    .search-container.active {
      width: 500px;
    }

    .search-close {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      z-index: 200;
      color: #333;
    }
  }

  /* ===============================
   MOBILE VIEW (<=1200px)
=============================== */
  @media (max-width: 1200px) {
    .custom-navbar {
      padding: 0 68px;
    }

    .hamburger {
      display: inline-flex;
      padding-left: 0;
    }

    .navbar-left .mobile-only {
      display: block !important;
    }

    .navbar-left ul {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 45px;
      left: 0;
      background: #363636;
      width: 100%;
      z-index: 99;
      padding: 0;
      min-height: 0;
    }

    .navbar-left ul.show {
      display: flex;
    }

    .navbar-left li {
      width: 100%;
      position: static !important;
      display: block !important;
    }

    li.divider {
      display: none !important;
    }

    .navbar-left a,
    .dropdown-toggle {
      width: 100%;
      justify-content: flex-start;
      padding: 12px 68px;
      height: auto;
      border-bottom: none;
    }

    .desktop-only {
      display: none !important;
    }

    .dropdown-menu-manual {
      position: static !important;
      width: 100%;
      background: #333;
      color: #fff;
      border-radius: 0;
      box-shadow: none;
      display: none;
    }

    .profile-dropdown .dropdown-toggle {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px 68px;
      color: #fff;
      background: transparent;
      border: none;
      cursor: pointer;
      width: 100%;
      text-align: left;
      border-width: 0.75px 0 0.75px 0;
      border-style: solid;
      border-color: #777777;
    }

    .profile-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .profile-name {
      font-weight: 600;
      font-size: 14px;
      line-height: 1.2;
      color: #fff;
    }

    .profile-email {
      font-size: 12px;
      color: #ccc;
      line-height: 1.2;
    }

    .dropdown-menu-manual a {
      color: #fff;
      padding-left: 90px;
      background: #363636;
    }

    .dropdown-menu-manual a:hover {
      background: #444;
    }

    .navbar-right {
      gap: 8px;
    }

    .search-container.active {
      position: absolute;
      right: 100px;
      left: 68px;
      width: auto;
      max-width: none;
      z-index: 100;
      transform: none;
    }

    .search-close {
      color: #ffffff;
    }
  }

  @media (max-width: 768px) {
    .custom-navbar {
      padding: 0 40px;
    }

    .hamburger {
      padding-left: 0;
    }

    .profile-dropdown .dropdown-toggle {
      padding: 8px 40px;
    }

    .navbar-left a,
    .dropdown-toggle {
      padding: 12px 40px;
    }

    .dropdown-menu-manual a {
      padding-left: 60px;
    }

    .search-container.active {
      right: 80px;
      left: 40px;
    }
  }

  @media (max-width: 468px) {
    .custom-navbar {
      padding: 0 15px;
    }

    .hamburger {
      padding-left: 0;
    }

    .profile-dropdown .dropdown-toggle {
      padding: 8px 15px;
    }

    .dropdown-menu-manual a {
      padding-left: 32px !important;
    }

    .navbar-left a,
    .dropdown-toggle {
      padding: 12px 15px;
    }

    .search-container.active {
      right: 45px;
      left: 15px;
    }
  }
</style>
<script>
  window.userEmail = `Anonymous User`;
</script>

<script>
  window.SecureLinkHandler = (function () {
    const userEmail = window.userEmail || "Anonymous User";
    const currentEnvironment = window.location.hostname.split('.')[0];

    function safeAjax(ajaxOptions) {
      const deferredAjax = $.Deferred();
      shell.getTokenDeferred().done(function (token) {
        ajaxOptions.headers = ajaxOptions.headers || {};
        ajaxOptions.headers["__RequestVerificationToken"] = token;
        ajaxOptions.headers["Accept"] = "application/json";
        $.ajax(ajaxOptions)
          .done((data, textStatus, jqXHR) => deferredAjax.resolve(data, textStatus, jqXHR))
          .fail((xhr) => {
            deferredAjax.reject(xhr);
          });
      }).fail(() => deferredAjax.rejectWith(this, arguments));
      return deferredAjax.promise();
    }

    function getMpnIdByEmail(userEmail) {
      if (!userEmail.includes("@")) return Promise.resolve(null);

      const domain = userEmail.substring(userEmail.indexOf('@') + 1).toLowerCase();
      const url = "/_api/dev_pcwhitelisteddomains?$select=dev_domainname,dev_haspartnerid&$filter=dev_domainname eq '" + encodeURIComponent(domain) + "'";

      return safeAjax({
        type: "GET",
        url: url,
        contentType: "application/json"
      }).then((response) => {
        const records = response.value || [];
        if (records.length > 0 && Number(records[0].dev_haspartnerid) === 1) {
          return 1;
        } else {
          return null;
        }
      });
    }

    function handleProtectedNavigation(event, element, isProtected = 0) {
      event.preventDefault();

      let targetUrl = element.getAttribute("data-href");

      if (!targetUrl) {
        return;
      }

      targetUrl = targetUrl.replace(/microsoftpartners(dev|-uat|-prod)/, currentEnvironment);

      if (isProtected == 1 && userEmail === "Anonymous User") {
        window.location.href = `/Account/Login?returnUrl=${encodeURIComponent(targetUrl)}`;
      } else if (isProtected == 1) {
        window.open(targetUrl, "_blank");
      } else {
        window.open(targetUrl, "_blank");
      }
    }

    return {
      handleProtectedNavigation
    };
  })();
</script>
<script>
  window.userEmail = `Anonymous User`;
