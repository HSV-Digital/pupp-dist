	<script type="text/javascript">const bgLoaders = document.querySelectorAll(".solution-card[data-filename]");

async function loadBackgroundsAsync() {
    if (!window.ImageHandler || typeof window.ImageHandler.displayImageSecurely !== "function") {
        bgLoaders.forEach(bg => bg.style.setProperty("--bg-image", "none"));
        return;
    }

    const bgPromises = Array.from(bgLoaders).map(async (bgElement) => {
        const filename = bgElement.dataset.filename;
        const bgId = bgElement.id;

        if (!filename || !bgId) {
            bgElement.style.setProperty("--bg-image", "none");
            return;
        }

        try {
            const blobUrl = await window.ImageHandler.displayImageSecurely(filename, bgId, 0);

            if (blobUrl) {
                bgElement.style.setProperty("--bg-image", `url(${blobUrl})`);
                bgElement.classList.add("bg-loaded");
            } else {
                bgElement.style.setProperty("--bg-image", "none");
            }
        } catch (err) {
            console.error(err);
            bgElement.style.setProperty("--bg-image", "none");
        }
    });

    await Promise.allSettled(bgPromises);
}


loadBackgroundsAsync();


// NEW CAROUSEL SCRIPT

document.addEventListener("DOMContentLoaded", function () {
    const cards = document.querySelectorAll(".text-content");

    const imageLoaders = document.querySelectorAll(".card-image-loader");


    async function loadImagesAsync() {
        if (!window.ImageHandler || typeof window.ImageHandler.displayImageSecurely !== "function") {
            imageLoaders.forEach(img => img.src = "#");
            return;
        }

        const loadPromises = Array.from(imageLoaders).map(imgElement => {
            const filename = imgElement.dataset.filename;
            const imgId = imgElement.id;
            const isProtected = parseInt(imgElement.dataset.isprotected || "0", 10);
            const shimmer = imgElement.previousElementSibling;

            if (filename && imgId) {
                return window.ImageHandler.displayImageSecurely(filename, imgId, isProtected)
                    .then(() => {
                        imgElement.classList.remove("hidden");
                        if (shimmer) shimmer.remove();
                    })
                    .catch(error => {
                        imgElement.src = "#";
                        imgElement.classList.remove("hidden");
                        if (shimmer) shimmer.remove();
                    });
            } else {
                imgElement.src = "#";
                imgElement.classList.remove("hidden");
                if (shimmer) shimmer.remove();
                return Promise.resolve();
            }
        });

        await Promise.allSettled(loadPromises);
    }

    loadImagesAsync();
});


document.addEventListener("DOMContentLoaded", function () {
    let currentSlide = 0;
    const track = document.getElementById("carouselTrack");
    const dots = document.querySelectorAll(".carousel-dots .dot");
    const totalSlides = dots.length;

    const pauseSvg = `
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
          xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" stroke="#242424" stroke-width="1.5"/>
        <rect x="9" y="8" width="2" height="8" fill="#242424"/>
        <rect x="13" y="8" width="2" height="8" fill="#242424"/>
      </svg>`;

    const playSvg = `
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
          xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" stroke="#242424" stroke-width="1.5"/>
        <path d="M10 8L16 12L10 16V8Z" fill="#242424"/>
      </svg>`;


    const playPauseBtn = document.getElementById('playPauseBtn');
    let interval;
    let isPaused = false;

    function moveToSlide(index) {
        const firstMainCard = document.querySelector(".main-card");
        if (!firstMainCard) return;

        const cardWidth = firstMainCard.offsetWidth;
        currentSlide = index;

        // keep sliding effect
        track.style.transform = `translateX(-${index * cardWidth}px)`;

        // show only the active card
        const allCards = document.querySelectorAll(".main-card");
        allCards.forEach((card, i) => {
            card.classList.toggle("active", i === index);
        });

        updateDots();
    }



    function nextSlide() {
        currentSlide = (currentSlide + 1) % totalSlides;
        moveToSlide(currentSlide);
    }

    function updateDots() {
        dots.forEach((dot, i) => {
            dot.classList.remove('active');
        });

        if (dots[currentSlide]) {
            dots[currentSlide].classList.add('active');
        }
    }


    dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
            moveToSlide(index);
            resetAutoSlide();
        });
    });

    function startAutoSlide() {
        if (interval) clearInterval(interval);
        interval = setInterval(() => {
            if (!isPaused) {
                nextSlide();
            }
        }, 5000);
    }

    function resetAutoSlide() {
        clearInterval(interval);
        startAutoSlide();
    }

    if (playPauseBtn) {
        playPauseBtn.innerHTML = pauseSvg;
        playPauseBtn.setAttribute('aria-label', 'Pause carousel');
        playPauseBtn.addEventListener('click', () => {
            isPaused = !isPaused;
            playPauseBtn.innerHTML = isPaused ? playSvg : pauseSvg;
            playPauseBtn.setAttribute('aria-label', isPaused ? 'Play carousel' : 'Pause carousel');
            if (!isPaused) {
                startAutoSlide();
            } else {
                clearInterval(interval);
            }
        });
    }

    window.addEventListener("resize", () => {
        moveToSlide(currentSlide);
    });

    moveToSlide(currentSlide);
    startAutoSlide();
});</script>
	
	<script>
        //this event will update the title of the page based on active breadcrumb
        $('.breadcrumb').ready(function () {
            if ($('.breadcrumb').is(':visible')) {
                document.querySelector('title').innerHTML = ($('.breadcrumb > li.active').text() + "");
            }
        });

        function GoToNewEditor() {
            var editCmsUrlSegment = "EditInCms";
            var currentUrl = window.location.href;
            if (currentUrl.indexOf('?') > -1) {
                var urlSegments = currentUrl.split("?");
                window.location.href = window.location.origin + '/' + editCmsUrlSegment + window.location.pathname + '?' + urlSegments[1];
            }
            else {
                window.location.href = window.location.origin + '/' + editCmsUrlSegment + window.location.pathname;
            }
        }
    </script>
	
		
		
	
		
				<script>
					if ('serviceWorker' in navigator) {
						navigator.serviceWorker.getRegistrations().then(function (registrations) {
							for (let registration of registrations) {
								registration.unregister();
							}
						}).catch(function (err) {
							console.log('Service Worker unregister action failed: ', err);
						});
					}
				</script>
			
	
		
