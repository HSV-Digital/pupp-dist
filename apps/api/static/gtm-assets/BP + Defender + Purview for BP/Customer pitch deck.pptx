		<style type="text/css">.body {
    font-family: 'Segoe UI';
    background-color: #ffffff;
}

.carousel-track .main-card {
    height: 455px;
    min-height: 455px !important;
}

h2 {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #242424;
}

p {
    font-size: 14px;
    font-weight: 400;
    color: #242424;
    margin-top: 0;
}

/* === GLOBAL CONTAINER === */
.page-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 68px !important;
    box-sizing: border-box;
}

/* === GRID LAYOUT (2x2) === */
.two-column-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto auto;
    gap: 32px;
    align-items: start;
}

.left-section {
    grid-column: 1;
    grid-row: 1;
}

.right-section {
    grid-column: 2;
    grid-row: 1;
}

.solution-left {
    grid-column: 1;
    grid-row: 2;
}

.solution-right {
    grid-column: 2;
    grid-row: 2;
}

/* === LEFT SECTION (CAROUSEL) === */
.left-section {
    background-color: white;
    border-radius: 8px;
    min-width: 0;
}

/* === RIGHT SECTION (UPDATES) === */
.right-section {
    background-color: white;
    border-radius: 8px;
    padding: 20px 0px;
    display: flex;
    flex-direction: column;
    min-width: 0;
}

.right-section h2 {
    margin-top: 0;
}

.alert-list-wrapper {
    overflow: hidden;
    margin-top: 5px;
    position: relative;
}

.view-all-alerts {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: #0F6CBD;
    font-weight: 400;
    text-decoration: none;
}

.view-all-alerts svg {
    display: inline-block;
    vertical-align: middle;
    margin-top: 2px;
}

.view-all-alerts:hover {
    color: #0F6CBD;
    text-decoration: none !important;
}

/* === SOLUTION SECTION (BOTTOM LEFT) === */
.solution-left h2 {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 8px;
    margin-top: 0px;
    color: #242424;
}

.solution-left p {
    font-size: 16px;
    font-weight: 400;
    margin-bottom: 6px;
    color: #242424;
}

/* === SOLUTION RIGHT (STAY CONNECTED) === */
.solution-right {
    background-color: #fafafa;
    border-radius: 4px;
    padding: 32px;
    box-shadow: rgba(0, 0, 0, 0.03) 0px 2px 4px;
    display: flex;
    flex-direction: column;
    gap: 48px;
}

.solution-right h2 {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 8px;
    margin-top: 0px;
    color: #242424;
}

/* === SOLUTION CARDS === */
.solution-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 20px;
}

.solution-card-button {
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  min-width: 190px;
}

.solution-card {
  position: relative;
  overflow: hidden;
  border-radius: 6px;
  height: 250px;
  width: 100%;
}

.solution-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: var(--bg-image) !important;
  background-size: cover;
  background-position: center;
  transform: scale(1);
  transition: transform 0.8s ease, opacity 0.4s ease;
  z-index: 0;
  opacity: 0;
}

.solution-card.bg-loaded::before {
  opacity: 1;
}

.solution-card:hover::before {
  transform: scale(1.1);
}

.solution-card:hover::before {
    transform: scale(1.1);
}

.solution-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, #0F6CBD 0%, transparent 100%);
    opacity: 0.;
    transition: opacity 0.3s ease;
    z-index: 1;
}

.card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 15px;
    text-align: left;
    z-index: 2;
}

.card-content h3 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
    line-height: 32px;
    color: #ffffff;
}

/* === RESOURCE LINKS === */
.resource-links {
    display: flex;
    flex-direction: column;
    gap: 32px;
}

.resource-link {
    display: flex;
    align-items: center;
    font-size: 14px;
    font-weight: 400;
    padding: 5px 0;
    color: #0F6CBD;
    text-decoration: none !important;
    gap: 16px;
}

.resource-link span {
    font-size: 18px;
    line-height: 1;
}

.resource-link .link-text {
    display: inline;
    font-size: 14px;
    font-weight: 400;
    padding: 5px 0;

}

.resource-link .arrow {
    display: inline-flex;
    margin-left: 6px;
}

a.resource-link:hover {
    color: #0F6CBD;
    text-decoration: none !important;
}

/* === MEDIA QUERIES === */
@media (max-width: 1280px) {
    .solution-cards {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 1024px) {
    .two-column-layout {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
    }

    /* Reset explicit placement so they follow normal flow */
    .left-section,
    .right-section,
    .solution-left,
    .solution-right {
        grid-column: 1 !important;
        grid-row: auto !important;
    }
}

@media (max-width: 900px) {
    .solution-cards {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .page-container {
        padding: 40px !important;
    }
}

@media (max-width: 600px) {
    .solution-cards {
        grid-template-columns: 1fr;
    }

    .card-content h3 {
        font-size: 20px;
        line-height: 26px;
    }

    h2 {
        font-size: 22px;
    }

    p {
        font-size: 14px;
    }
}

@media (max-width: 468px) {
    .page-container {
        padding: 15px !important;
    }
}

@media (max-width: 400px) {
    .card-content h3 {
        font-size: 18px;
        line-height: 24px;
    }
}

.sectionBlockLayout {
    flex-wrap: wrap;
    padding: 8px;
    margin: 0px;
    display: none;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
}

/* Alert Card styles */

.alert-card {
    background-color: white;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 10px;
    /* box-shadow: rgba(0, 0, 0, 0.05) 0px 4px 8px; */
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 145px;
  }

  .alert-header-vertical {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: 5px;
    row-gap: 6px;
  }

  .tag-line {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .badge {
    padding: 4px 10px;
    font-size: 10px;
    border-radius: 9999px;
    font-weight: 600;
    background-color: #091F2C;
    color: #ffffff;
    display: inline-block;
    white-space: nowrap;
  }

  .alert-header-vertical .alert-title {
    font-weight: 600;
    font-size: 14px;
    color: #272727;
    margin: 0;
    max-width: 100%;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .alert-card p {
    font-size: 12px;
    font-weight: 400;
    color: #707070;
    margin: 0;
  }

  .bottom-link {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bottom-link .card-link {
    font-size: 14px;
    font-weight: 400;
    color: #0f6cbd;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: none !important;
    padding: 0;
    margin: 0;
  }

  .bottom-link .card-link svg {
    display: inline-block;
    vertical-align: middle;
    margin-top: 3px;
  }

  a.card-link:hover {
    text-decoration: none !important;
  }</style>
		
		
		
		
	
		
