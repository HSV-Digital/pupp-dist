</script>

<script>
  window.FileDownloadHandler = (function () {
    function getUserEmail() {
      return window.userEmail || "Anonymous User";
    }

    function getUserSession() {
      return window.sessionId || "Anonymous Session";
    }

    function safeAjax(ajaxOptions) {
      const deferredAjax = $.Deferred();
      shell.getTokenDeferred().done(function (token) {
        ajaxOptions.headers = ajaxOptions.headers || {};
        ajaxOptions.headers["__RequestVerificationToken"] = token;
        ajaxOptions.headers["Accept"] = "application/json";
        $.ajax(ajaxOptions)
          .done((data, textStatus, jqXHR) => deferredAjax.resolve(data, textStatus, jqXHR))
          .fail((xhr) => {
            deferredAjax.reject(xhr);
          });
      }).fail(() => deferredAjax.rejectWith(this, arguments));
      return deferredAjax.promise();
    }

    function getMpnIdByEmail(userEmail) {
      if (!userEmail.includes("@")) return Promise.resolve(null);

      const domain = userEmail.substring(userEmail.indexOf('@') + 1).toLowerCase();
      const url = "/_api/dev_pcwhitelisteddomains?$select=dev_domainname,dev_haspartnerid&$filter=dev_domainname eq '" + encodeURIComponent(domain) + "'";

      return safeAjax({
        type: "GET",
        url: url,
        contentType: "application/json"
      }).then((response) => {
        const records = response.value || [];
        if (records.length > 0 && Number(records[0].dev_haspartnerid) === 1) {
          return 1;
        } else {
          return null;
        }
      });
    }

    async function generateDownloadGUID(filename, isProtected = 0) {
      const userEmail = getUserEmail();
      const userSession = getUserSession();
      const hasMPN = await getMpnIdByEmail(userEmail);

      try {
        if (isProtected == 1 && userEmail === "Anonymous User") {
          const returnUrl = encodeURIComponent(window.location.pathname + window.location.search + window.location.hash);
          window.location.href = `/signin?returnurl=${returnUrl}`;
          return;
        }

        let guid = null;
        await safeAjax({
          type: "POST",
          url: "/_api/dev_filedownloadses",
          contentType: "application/json",
          data: JSON.stringify({
            dev_username: userSession,
            dev_isprotected: isProtected  ? '1' : '0',
            dev_filename: filename,
            dev_isgenerated: "no"
          }),
          success: (res, status, xhr) => {
            guid = xhr.getResponseHeader("entityid");
          }
        });
        return guid;
      } catch (error) {
        console.error("Error generating download GUID:", error);
        return;
      }
    }

    async function handleElementDownload(event, element, isProtected = 0) {
      event.preventDefault();
      const filename = element.getAttribute("data-filename");
      if (!filename) return;

      const guid = await generateDownloadGUID(filename, isProtected);
      if (!guid) return;

      const downloadUrl = `/download-page?guid=${encodeURIComponent(guid)}`;
      window.open(downloadUrl, "_blank");
    }

    return {
      handleElementDownload
    };
  })();
</script>
<script>
(() => {
    // Initialize global values only once
    if (!window.userEmail) {
        window.userEmail = `Anonymous User`;
    }

    if (!window.azureFunctionBaseUrl) {
        window.azureFunctionBaseUrl = "https://mws-transformsite-functionapp-prod-gtdaftg8egc0gtcc.eastus2-01.azurewebsites.net";
    }

    const AzureBaseUrl = window.azureFunctionBaseUrl;

    // Avoid redefining ImageHandler if it already exists
    if (!window.ImageHandler) {
        window.ImageHandler = (() => {
            const userEmail = window.userEmail || "Anonymous User";
            const statusElement = document.getElementById("imageStatus");

            function updateStatus(message, isError = false) {
                if (statusElement) {
                    statusElement.textContent = message;
                    statusElement.className = isError ? "error-message" : "loading-text";
                }
            }

            function safeAjax(ajaxOptions) {
                const deferredAjax = $.Deferred();
                if (typeof shell === 'undefined' || typeof shell.getTokenDeferred === 'undefined' || typeof $ === 'undefined') {
                    updateStatus("System error: Dependencies missing.", true);
                    deferredAjax.reject("Dependencies missing");
                    return deferredAjax.promise();
                }

                shell.getTokenDeferred().done(function (token) {
                    ajaxOptions.headers = ajaxOptions.headers || {};
                    ajaxOptions.headers["__RequestVerificationToken"] = token;
                    ajaxOptions.headers["Accept"] = "application/json";
                    $.ajax(ajaxOptions)
                        .done((data, textStatus, jqXHR) => deferredAjax.resolve(data, textStatus, jqXHR))
                        .fail((xhr) => {
                            const errorMsg = xhr.responseJSON || xhr.responseText || xhr;
                            updateStatus(`API error: ${JSON.stringify(errorMsg)}.`, true);
                            deferredAjax.reject(xhr);
                        });
                }).fail(() => {
                    updateStatus("Security token acquisition failed.", true);
                    deferredAjax.reject("Token acquisition failed");
                });

                return deferredAjax.promise();
            }

            function createErrorSvgElement(id) {
                const wrapper = document.createElement("div");
                wrapper.innerHTML = `
                    <div class="error-image-placeholder" id="error-placeholder-${id}">
                        <svg width="38" height="29" viewBox="0 0 38 29" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M32.3271 26.3757V8.0105C32.3271 7.02288 31.5265 6.22226 30.5389 6.22226L1.78841 6.22226C0.800789 6.22226 0.000164032 7.02288 0.000164032 8.0105V26.3757C0.000164032 27.3634 0.800789 28.164 1.78841 28.164L30.5389 28.164C31.5265 28.164 32.3271 27.3634 32.3271 26.3757Z" fill="#E6E6E6"/>
                            <path d="M25.4782 14.6717C25.2773 14.4431 25.0299 14.2599 24.7525 14.1345C24.4752 14.009 24.1743 13.9441 23.8699 13.9441C23.5655 13.9441 23.2646 14.009 22.9873 14.1345C22.71 14.2599 22.4626 14.4431 22.2616 14.6717L14.4671 23.5458L10.8795 19.3211C10.6784 19.0846 10.4284 18.8945 10.1466 18.7642C9.86484 18.6339 9.55811 18.5664 9.24767 18.5664C8.93724 18.5664 8.63051 18.6339 8.34875 18.7642C8.06699 18.8945 7.81692 19.0846 7.61589 19.3211L0.532227 27.6611C0.86658 27.9903 1.31693 28.1749 1.7862 28.1751H30.5367C31.011 28.1751 31.4658 27.9868 31.8012 27.6514C32.1365 27.316 32.3249 26.8612 32.3249 26.3869V22.4662L25.4782 14.6717Z" fill="#B3B3B3"/>
                            <path d="M9.82653 14.7097C11.2252 14.7097 12.3592 13.5758 12.3592 12.1771C12.3592 10.7784 11.2252 9.6445 9.82653 9.6445C8.42782 9.6445 7.29395 10.7784 7.29395 12.1771C7.29395 13.5758 8.42782 14.7097 9.82653 14.7097Z" fill="#616161"/>
                            <path d="M32 12.2223C35.3137 12.2223 38 9.53597 38 6.22226C38 2.90855 35.3137 0.22226 32 0.22226C28.6863 0.22226 26 2.90855 26 6.22226C26 9.53597 28.6863 12.2223 32 12.2223Z" fill="#616161"/>
                            <path d="M29.8179 3.9744L34.1795 8.47206" stroke="white" stroke-width="1.74262" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M34.2476 4.04236L29.7504 8.402" stroke="white" stroke-width="1.74262" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <div class="error-text">
                            <strong>Image failed to load</strong>
                        </div>
                    </div>`;
                return wrapper.firstElementChild;
            }

            async function handleError(err, guid, imgElementId) {
                updateStatus(`Error: ${err.message}`, true);
                const imgElement = document.getElementById(imgElementId);
                if (imgElement && imgElement.parentNode) {
                    const errorSvg = createErrorSvgElement(imgElementId);
                    imgElement.replaceWith(errorSvg);
                }
            }

            function escapeODataString(value) {
                return value.replace(/'/g, "''");
            }

            async function displayImageSecurely(filename, imgElementId, isProtected = 0) {
                let guid = null;
                const safeFilename = escapeODataString(filename);

                try {
                    // Check access for protected images
                    if (isProtected === 1 && userEmail === "Anonymous User") {
                        const returnUrl = encodeURIComponent(window.location.pathname + window.location.search + window.location.hash);
                        window.location.href = `/signin?returnurl=${returnUrl}`;
                        return;
                    }

                    // Query for existing record
                    const queryUrl = `/_api/dev_imagedownloadses?$select=dev_imagepath,dev_imagedownloadsid&$filter=dev_imagepath eq '${encodeURIComponent(safeFilename)}'`;
                    const getResponse = await safeAjax({
                        type: "GET",
                        url: queryUrl,
                        contentType: "application/json"
                    });

                    if (getResponse.value?.length > 0) {
                        guid = getResponse.value[0].dev_imagedownloadsid;
                    } else {
                        // Create new record
                        const postResponse = await safeAjax({
                            type: "POST",
                            url: "/_api/dev_imagedownloadses",
                            contentType: "application/json",
                            data: JSON.stringify({ dev_imagepath: filename }),
                            success: (res, status, xhr) => {
                                guid = xhr.getResponseHeader("entityid");
                            }
                        });

                        if (!guid) {
                            const xhrGuid = postResponse?.getResponseHeader?.("entityid");
                            if (xhrGuid) guid = xhrGuid;
                        }

                        if (!guid) throw new Error("New GUID not returned after record creation.");
                    }

                    const imgElement = document.getElementById(imgElementId);
                    if (!imgElement) throw new Error(`Image element with ID '${imgElementId}' not found.`);

                    imgElement.src = `${AzureBaseUrl}/api/fetchblobimage?id=${guid}`;
                    imgElement.alt = filename;
                    // imgElement.onerror = () => handleError(new Error(`Failed to load image '${filename}'.`), guid, imgElementId);
                    imgElement.onerror = () => {
                        console.warn(`Image failed: ${filename}`);
                        imgElement.dataset.loadFailed = "true";
                        imgElement.removeAttribute("src");
                        const errorSvg = createErrorSvgElement(imgElementId);
                        imgElement.replaceWith(errorSvg);
                    };

                    const blobUrl = `${AzureBaseUrl}/api/fetchblobimage?id=${guid}`;
                    return blobUrl;
                } catch (err) {
                    await handleError(err, guid, imgElementId);
                }
            }

            return { displayImageSecurely };
        })();
    }
})();
</script>

<style>
.error-image-placeholder {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    padding: 1rem;
    box-sizing: border-box;
    background-color: #f0f0f0;
    color: #666;
    font-family: Arial, sans-serif;
    text-align: center;
    border: 1px solid #ddd;
    border-radius: 4px;
    user-select: none;
    gap: 1rem;
}
.error-image-placeholder svg {
    width: 40%;
    max-width: 150px;
    height: auto;
    opacity: 0.5;
}
.error-image-placeholder .error-text strong {
    font-size: 1.1rem;
}
</style>
